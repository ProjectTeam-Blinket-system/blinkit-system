<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.blinkitsystem.controller.CartController"
            style="-fx-background-color:#F5F5F5;">

    <!-- HEADER -->
    <top>
        <HBox spacing="15"
              alignment="CENTER_LEFT"
              style="-fx-background-color:white;
                     -fx-padding:15 25;
                     -fx-border-color:#EAEAEA;
                     -fx-border-width:0 0 1 0;">

            <Button text="←"
                    onAction="#goBack"
                    style="-fx-background-color:#F1F3F6;
                           -fx-background-radius:10;"/>

            <Label text="Your Cart"
                   style="-fx-font-size:20;
                          -fx-font-weight:bold;"/>

        </HBox>
    </top>

    <!-- ITEMS -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color:transparent;">
            <content>
                <VBox fx:id="cartItemsBox"
                      spacing="15"
                      style="-fx-padding:20;"/>
            </content>
        </ScrollPane>
    </center>

    <!-- TOTAL -->
    <bottom>
        <HBox spacing="20"
              alignment="CENTER_RIGHT"
              style="-fx-padding:20;
                     -fx-background-color:white;
                     -fx-border-color:#EAEAEA;
                     -fx-border-width:1 0 0 0;">

            <Label text="Total:"
                   style="-fx-font-size:16;
                          -fx-font-weight:bold;"/>

            <Label fx:id="totalLabel"
                   style="-fx-font-size:18;
                          -fx-font-weight:bold;"/>

            <Button text="Checkout"
                    onAction="#checkout"
                    style="-fx-background-color:#0C8F45;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-background-radius:10;
                           -fx-padding:10 20;"/>

        </HBox>
    </bottom>

</BorderPane>